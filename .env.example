# Шаблон переменных окружения TakeWord. Скопируй в .env и заполни.
# Этот файл (без значений) коммитится; реальный .env — нет. Гайд: docs/SETUP-recognition.md

# ── ПРИЛОЖЕНИЕ (Expo) — публичные ──
EXPO_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_PROJECT_REF=<ref>

# Apple IAP через RevenueCat (только iOS). Публичный SDK-ключ вида appl_...
# Дашборд RevenueCat → Project → API keys → Apple. Гайд: docs/SETUP-iap.md.
# Без ключа оплата на iOS — no-op (пейволл показывает статичный вид). Web — на Polar.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=<appl_...>

# ── СЕРВЕР (Supabase Edge Function secret) — НЕ попадает в приложение ──
# Провайдер распознавания (OpenRouter, работает из Казахстана). Ключ: https://openrouter.ai/keys
RECOGNIZE_BASE_URL=https://openrouter.ai/api/v1
RECOGNIZE_MODEL=google/gemini-2.5-flash-lite
RECOGNIZE_API_KEY=<openrouter-key sk-or-v1-...>

# Токен для деплоя функции (Supabase → Account → Access Tokens)
SUPABASE_ACCESS_TOKEN=<sbp-...>

# Секрет вебхука RevenueCat. Придумай длинную случайную строку и впиши ОДНО И ТО ЖЕ
# значение здесь и в дашборде RevenueCat (Webhook → Authorization header).
# Ставится как секрет функции: supabase secrets set REVENUECAT_WEBHOOK_AUTH=...
REVENUECAT_WEBHOOK_AUTH=<длинная-случайная-строка>
